{
  "datasets": [
    {
      "name": "deb99835",
      "displayName": "Location Data",
      "queryLines": [
        "USE CATALOG `emissions`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "select latitude, longitude, `GHG emissions mtons CO2e` as emissions\n",
        "from emissions_data_2023"
      ]
    },
    {
      "name": "ce9a883d",
      "displayName": "Emissions per person",
      "queryLines": [
        "USE CATALOG `emissions`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "select county_state_name, population, \n",
        "       cast(replace(`GHG emissions mtons CO2e`, ',', '') as double) as emissions,\n",
        "       cast(replace(`GHG emissions mtons CO2e`, ',', '') as double) / population as emission_per_person\n",
        "from emissions_data_2023\n",
        "order by emission_per_person desc"
      ]
    },
    {
      "name": "1b4b8fcd",
      "displayName": "Total Emissions per state",
      "queryLines": [
        "USE CATALOG `emissions`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "select state_abbr, \n",
        "       sum(cast(replace(`GHG emissions mtons CO2e`, ',', '') as double)) as total_emissions\n",
        "from emissions_data_2023\n",
        "group by state_abbr\n",
        "order by total_emissions desc\n",
        "limit 10"
      ]
    },
    {
      "name": "5f8cf3aa",
      "displayName": "Emissions by County",
      "queryLines": [
        "USE CATALOG `emissions`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "select county_state_name,population,\n",
        "       cast(replace(`GHG emissions mtons CO2e`, ',', '') as double) as emissions\n",
        "from emissions_data_2023\n",
        "order by emissions desc\n",
        "limit 10"
      ]
    }
  ],
